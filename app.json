{
  "expo": {
    "name": "Ortodoxia",
    "slug": "magyar-ortodoxia-app",
    "version": "1.0.0",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "myapp",
    "ios": {
      "supportsTablet": true,
      "icon": "assets/magyar-ortodox.icon",
      "bundleIdentifier": "com.leventezoltan.magyarortodoxia",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f5f5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.leventezoltan.magyarortodoxia"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
      "expo-build-properties",
        {
            "android": {
              "colorPrimary": "#fff",
              "colorPrimaryDark": "#121212",
              "colorAccent": "#8B0000"
            }
        }
      ],
      [
      "expo-splash-screen",
        {
          "backgroundColor": "#f5f5f5",
          "image": "./assets/splash-icon-light.png",
          "dark": {
            "image": "./assets/splash-icon-dark.png",
            "backgroundColor": "#121212"
          },
          "imageWidth": 200
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0402cd27-eafc-4a6c-a649-7ce5a22846d3"
      }
    }
  }
}
