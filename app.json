{
  "expo": {
    "name": "Ortodoxia",
    "slug": "magyar-ortodoxia-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "myapp",
    "splash": {
      "image": "./assets/cross.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f5f5"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "assets/magyar-ortodox.icon",
      "bundleIdentifier": "com.leventezoltan.magyarortodoxia",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/cross.png",
        "backgroundColor": "#f5f5f5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.leventezoltan.magyarortodoxia"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
      "expo-build-properties",
      {
          "android": {
            "colorPrimary": "#fff",
              "colorPrimaryDark": "#121212",
              "colorAccent": "#8B0000"
          }
      }
    ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0402cd27-eafc-4a6c-a649-7ce5a22846d3"
      }
    }
  }
}
